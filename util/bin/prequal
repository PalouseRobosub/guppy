#!/bin/bash
source ~/guppy/install/setup.bash

Z=-1.5
START_TO_GATE=3
GATE_TO_MARKER=10
Y_CHANGE=-1

T_THERE=60
T_STRAFE=15
T_BACK=60


TOTAL_X=$((START_TO_GATE + GATE_TO_MARKER))

echo -n setting nav state...
ros2 service call /change_state guppy_msgs/srv/ChangeState "{new_state:{state: 2}}" >> /dev/null
echo done

# echo -n resetting pose....
# ros2 service call /reset_holding_pose std_srvs/srv/Empty >> /dev/null
# echo done

echo -n down...
ros2 action send_goal --feedback /navigate guppy_msgs/action/Navigate \
    "{pose: {position: {x: 0, y: 0.0, z: 0}, orientation: {w: 1.0, x: 0.0, y: 0.0, z: 0.0}}, local: false, timeout: 3}" >> /dev/null
echo done


echo -n gate to marker...
ros2 action send_goal --feedback /navigate guppy_msgs/action/Navigate \
    "{pose: {position: {x: $TOTAL_X, y: 0.0, z: $Z}, orientation: {w: 1.0, x: 0.0, y: 0.0, z: 0.0}}, local: false, timeout: $T_THERE}" >> /dev/null
echo done

echo -n left to right side of marker...
ros2 action send_goal --feedback /navigate guppy_msgs/action/Navigate \
    "{pose: {position: {x: $TOTAL_X, y: $Y_CHANGE, z: $Z}, orientation: {w: 1.0, x: 0.0, y: 0.0, z: 0.0}}, local: false, timeout: $T_STRAFE}" >> /dev/null
echo done

echo -n back from marker...
ros2 action send_goal --feedback /navigate guppy_msgs/action/Navigate \
    "{pose: {position: {x: 0, y: $Y_CHANGE, z: $Z}, orientation: {w: 1.0, x: 0.0, y: 0.0, z: 0.0}}, local: false, timeout: $T_BACK}" >> /dev/null
echo done

